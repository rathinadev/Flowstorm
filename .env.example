# FlowStorm Backend Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Redis (ephemeral: streams, pub/sub, live metrics)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# PostgreSQL (persistent: pipeline versions, checkpoints)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=flowstorm
POSTGRES_PASSWORD=flowstorm
POSTGRES_DB=flowstorm

# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# Docker
WORKER_IMAGE=flowstorm-worker:latest
WORKER_NETWORK=flowstorm-net

# Health Monitor
HEARTBEAT_INTERVAL_MS=500
HEARTBEAT_TIMEOUT_MS=2000

# Optimizer
OPTIMIZER_INTERVAL_S=30
